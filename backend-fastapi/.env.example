APP_NAME=LockedIn API
APP_ENVIRONMENT=development
APP_API_PREFIX=/api/v1
APP_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173","http://127.0.0.1:8080"]
APP_ALLOWED_ORIGINS_REGEX=^https://.*\.vercel\.app$

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

RAPIDAPI_KEY=
JSEARCH_RAPIDAPI_HOST=jsearch.p.rapidapi.com
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com
JSEARCH_DEFAULT_QUERY=graduate internship opportunities united kingdom
JSEARCH_DEFAULT_QUERIES=software engineer internship united kingdom|technology graduate scheme united kingdom|finance internship united kingdom|investment banking summer analyst united kingdom|law vacation scheme united kingdom|graduate scheme united kingdom
JSEARCH_DEFAULT_NUM_PAGES=2
JSEARCH_MAX_NUM_PAGES=5
JSEARCH_TIMEOUT_SECONDS=20

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

APP_AUTH_COOKIE_NAME=lockedin_access_token
APP_CSRF_COOKIE_NAME=lockedin_csrf_token
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAMESITE=lax
APP_AUTH_COOKIE_DOMAIN=
APP_AUTH_COOKIE_MAX_AGE_SECONDS=3600
